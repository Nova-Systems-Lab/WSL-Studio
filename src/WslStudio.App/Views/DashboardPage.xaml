<Page
    x:Class="WslStudio.App.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:WslStudio.App.Controls"
    xmlns:viewModels="using:WslStudio.App.ViewModels"
    Loaded="OnLoaded">
    <ScrollViewer>
        <Grid
            MaxWidth="1180"
            Padding="32"
            HorizontalAlignment="Stretch"
            RowSpacing="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Style="{StaticResource PageSubtitleTextBlockStyle}" Text="{Binding Subtitle}" />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                x:Name="LoadingState"
                x:Load="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                HorizontalAlignment="Center"
                Spacing="12">
                <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Loading WSL overview..." />
            </StackPanel>

            <controls:InfoCard
                Grid.Row="1"
                x:Name="EmptyState"
                x:Load="{x:Bind ViewModel.IsEmpty, Mode=OneWay}"
                Title="No distributions found"
                Description="WSL did not report any installed distributions. This dashboard only shows real read-only data returned by WSL."
                Icon="Library" />

            <controls:InfoCard
                Grid.Row="1"
                x:Name="ErrorState"
                x:Load="{x:Bind ViewModel.HasError, Mode=OneWay}"
                Title="Dashboard overview could not load"
                Description="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Icon="Important" />

            <Grid
                Grid.Row="1"
                x:Name="OverviewState"
                x:Load="{x:Bind ViewModel.HasOverview, Mode=OneWay}"
                RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.OverviewCards, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout
                            MaximumRowsOrColumns="4"
                            MinItemWidth="220"
                            MinRowSpacing="16"
                            MinColumnSpacing="16" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:OverviewCardViewModel">
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Title}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        FontSize="28"
                                        FontWeight="SemiBold"
                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                        Text="{x:Bind Value}"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Description}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="48"
                            Height="48"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="8">
                            <SymbolIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                Symbol="Find" />
                        </Border>

                        <Grid Grid.Column="1" ColumnSpacing="24" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="WSL environment" />
                            <TextBlock
                                Grid.Row="1"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.WslStatus, Mode=OneWay}"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Grid.Column="1"
                                Style="{StaticResource SectionTitleTextBlockStyle}"
                                Text="WSL version" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.WslVersion, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Width="48"
                        Height="48"
                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8">
                        <SymbolIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Symbol="Home" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Style="{StaticResource SectionTitleTextBlockStyle}" Text="Read-only preview" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="The dashboard uses official read-only WSL commands. Lifecycle actions and destructive operations are intentionally not available here."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
